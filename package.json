{
  "name": "burro_dos_concertos",
  "version": "1.0.0",
  "description": "telegram concert manager bot",
  "main": "dist/bot.js",
  "exports": "./dist/bot.js",
  "imports": {
    "#/*": "./src/*"
  },
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "author": {
    "name": "Daniel Azeiteiro",
    "email": "daniel.azeiteiro@gmail.com"
  },
  "keywords": [
    "concerts",
    "telegram",
    "bot"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "tsx --watch src/bot.ts",
    "dev:test": "NODE_ENV=test tsx --watch src/bot.ts",
    "clean": "rimraf dist",
    "build": "pnpm clean && tsc && tsc-alias",
    "start": "node dist/bot.js",
    "test": "NODE_OPTIONS='--localstorage-file=./jest-storage' jest",
    "test:coverage": "NODE_OPTIONS='--localstorage-file=./jest-storage' jest --coverage",
    "test:ci": "NODE_OPTIONS='--localstorage-file=./jest-storage' jest --ci",
    "test:watch": "jest --watch",
    "format": "prettier --write \"src/**/*\" \"web/src/**/*\"",
    "lint": "eslint \"src/**/*.{js,ts}\"",
    "lint:fix": "pnpm lint --fix",
    "seed": "node dist/prisma/seed.js",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\""
  },
  "lint-staged": {
    "**/*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1076.0",
    "@grammyjs/conversations": "^2.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "chrono-node": "^2.9.1",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "got": "^15.0.7",
    "grammy": "^1.44.0",
    "ical-generator": "^11.0.0",
    "metascraper": "^5.51.1",
    "metascraper-date": "^5.51.1",
    "metascraper-description": "^5.51.1",
    "metascraper-image": "^5.51.1",
    "metascraper-title": "^5.51.1",
    "metascraper-url": "^5.51.1",
    "minimatch": "^10.2.5",
    "node-cron": "^4.5.0",
    "pino": "^10.3.1",
    "prisma": "7.8.0",
    "puppeteer-core": "^25.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.9.4",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
