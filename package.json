{
  "name": "burro_dos_concertos",
  "version": "1.0.0",
  "description": "telegram concert manager bot",
  "main": "dist/bot.js",
  "exports": "./dist/bot.js",
  "imports": {
    "#/*": "./src/*"
  },
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "author": {
    "name": "Daniel Azeiteiro",
    "email": "daniel.azeiteiro@gmail.com"
  },
  "keywords": [
    "concerts",
    "telegram",
    "bot"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "tsx --watch src/bot.ts",
    "dev:test": "NODE_ENV=test tsx --watch src/bot.ts",
    "clean": "rimraf dist",
    "build": "pnpm clean && tsc && tsc-alias",
    "start": "node dist/bot.js",
    "test": "NODE_OPTIONS='--localstorage-file=./jest-storage' jest --coverage",
    "test:ci": "NODE_OPTIONS='--localstorage-file=./jest-storage' jest --coverage --ci",
    "test:watch": "jest --watch",
    "format": "prettier --write \"src/**/*\" \"web/src/**/*\"",
    "lint": "eslint \"src/**/*.{js,ts}\"",
    "lint:fix": "pnpm lint --fix",
    "seed": "node dist/prisma/seed.js",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\""
  },
  "lint-staged": {
    "**/*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/typescript-estree>minimatch": "^9.0.7",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "hono@<4.11.7": ">=4.11.7",
      "hono@<4.11.10": ">=4.11.10",
      "yauzl@<3.2.1": ">=3.2.1",
      "flatted@<=3.4.1": ">=3.4.2",
      "effect@<3.20.0": ">=3.20.0",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@<5.0.5": ">=5.0.5",
      "handlebars@>=4.0.0 <4.7.9": ">=4.7.9",
      "path-to-regexp@>=8.0.0 <8.4.0": ">=8.4.0",
      "@hono/node-server": "1.19.13",
      "@prisma/dev>@hono/node-server": "1.19.13"
    }
  },
  "packageManager": "pnpm@11.0.9",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@grammyjs/conversations": "^2.1.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7.8.0",
    "chrono-node": "^2.9.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "got": "^15.0.5",
    "grammy": "^1.42.0",
    "ical-generator": "^10.2.0",
    "metascraper": "^5.50.3",
    "metascraper-date": "^5.50.1",
    "metascraper-description": "^5.50.1",
    "metascraper-image": "^5.50.1",
    "metascraper-title": "^5.50.1",
    "metascraper-url": "^5.50.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "prisma": "7.8.0",
    "puppeteer-core": "^24.43.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.2",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jiti": "^2.7.0",
    "lint-staged": "^17.0.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
